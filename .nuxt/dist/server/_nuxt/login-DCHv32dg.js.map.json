{"file":"login-DCHv32dg.js","mappings":";;;;;;;;;;;;;;;;;;;AAEO,MAAM,WAAW;AAAA,EACtB,OAAO,CAAC,YAAiB,iBAAiB,KAAK,eAAe,OAAO;AAAA,EACrE,UAAU,CAAC,YAAiB,iBAAiB,KAAK,kBAAkB,OAAO;AAC7E;ACAO,MAAM,WAAW,MAAM;AAC5B,QAAM,UAAU,IAAI,KAAK;AACzB,QAAM,EAAE,QAAA,IAAY,QAAA;AACpB,QAAM,EAAE,UAAA,IAAc,eAAA;AAEtB,QAAM,QAAQ,OAAO,YAAiB;AACpC,YAAQ,QAAQ;AAChB,QAAI;AACF,YAAM,MAAM,MAAM,SAAS,MAAM,OAAO;AACxC,YAAM,EAAE,MAAM,MAAA,IAAU,IAAI;AAC5B,cAAQ,MAAM,KAAK;AACnB,gBAAU;AAAA,QACR,OAAO;AAAA,QACP,SAAS;AAAA,QACT,WAAW;AAAA,MAAA,CACZ;AACD,aAAO,IAAI;AAAA,IACb,SAAS,OAAY;AACnB,gBAAU;AAAA,QACR,OAAO;AAAA,QACP,SAAS,MAAM,UAAU,MAAM,WAAW;AAAA,QAC1C,WAAW;AAAA,MAAA,CACZ;AAAA,IACH,UAAA;AACE,cAAQ,QAAQ;AAAA,IAClB;AAAA,EACF;AAEA,SAAO,EAAE,SAAS,MAAA;AACpB;;;;;ACkEA,UAAM,EAAE,QAAe,IAAI,SAAQ;AACpB,cAAS;AAExB,UAAM,OAAO,SAAS;AAAA,MACpB,OAAO;AAAA,MACP,UAAU;AAAA,IACZ,CAAC;;;AAzGM,YAAA,OAAAA,eAAAC,WAAA,EAAA,OAAM,8GAA0G,MAAA,CAAA,CAAA,6fAAA;;QAWzF,MAAM;AAAA,QAAI,OAAM;AAAA;;;QAgBzB,YAAA,KAAK;AAAA,QAAL,uBAAA,YAAA,KAAK,QAAK;AAAA,QACnB,MAAK;AAAA,QACL,OAAM;AAAA,QACN,aAAY;AAAA;QAED,eAAX,CAEW,GAAAC,QAAAC,UAAA,aAAA;;;cADI,MAAM;AAAA,cAAI,OAAM;AAAA;;;cAA7BC,YAAoGC,MAAA,UAAA,GAAA;AAAA,gBAAvF,MAAM;AAAA,gBAAI,OAAM;AAAA;;;;;;;;QAOpB,YAAA,KAAK;AAAA,QAAL,uBAAA,YAAA,KAAK,WAAQ;AAAA,QACtB,MAAK;AAAA,QACL,OAAM;AAAA,QACN,aAAY;AAAA;kFASDA,MAAA,OAAA,CAAO,IAAA,cAAA,EAAA,qMAAA;UAGNA,MAAA,OAAA,GAAO;;;;AAGE,cAAAC,mBAAAD,MAAA,gBAAA,GAAA,EAAA,MAAM,GAAE,GAAA,MAAA,OAAA,CAAA;;;;;QAiBvB,IAAG;AAAA,QAAU,OAAM;AAAA;yBAA7B,CAAuG,GAAAH,QAAAC,UAAA,aAAA;;;;;8BAA/B,sBAAoB;AAAA;;;;;;;;;;;;;;;","names":["_ssrRenderAttrs","_mergeProps","_push","_parent","_createVNode","_unref","_ssrRenderComponent"],"sources":["../../../../api_factory/modules/auth.ts","../../../../composables/modules/auth/useLogin.ts","../../../../pages/login.vue"],"sourcesContent":["import { GATEWAY_ENDPOINT } from \"../axios.config\";\n\nexport const auth_api = {\n  login: (payload: any) => GATEWAY_ENDPOINT.post(\"/auth/login\", payload),\n  register: (payload: any) => GATEWAY_ENDPOINT.post(\"/auth/register\", payload),\n};\n","import { ref } from 'vue'\nimport { auth_api } from '@/api_factory/modules/auth'\nimport { useUser } from './user'\nimport { useCustomToast } from '@/composables/core/useCustomToast'\n\nexport const useLogin = () => {\n  const loading = ref(false)\n  const { setUser } = useUser()\n  const { showToast } = useCustomToast()\n\n  const login = async (payload: any) => {\n    loading.value = true\n    try {\n      const res = await auth_api.login(payload)\n      const { user, token } = res.data\n      setUser(user, token)\n      showToast({\n        title: 'Success',\n        message: 'Logged in successfully',\n        toastType: 'success'\n      })\n      return res.data\n    } catch (error: any) {\n      showToast({\n        title: 'Error',\n        message: error.response?.data?.message || 'Login failed',\n        toastType: 'error'\n      })\n    } finally {\n      loading.value = false\n    }\n  }\n\n  return { loading, login }\n}\n","<template>\n  <div class=\"min-h-screen bg-slate-50 flex items-center justify-center p-6 lg:p-12 relative overflow-hidden font-sans\">\n    <!-- Sophisticated Background Decor -->\n    <div class=\"absolute inset-0 overflow-hidden pointer-events-none opacity-40\">\n      <div class=\"absolute top-[-10%] right-[-10%] w-[50%] h-[50%] bg-[#003366]/5 rounded-full blur-[100px]\"></div>\n      <div class=\"absolute bottom-[-10%] left-[-10%] w-[40%] h-[40%] bg-[#00707E]/5 rounded-full blur-[100px]\"></div>\n    </div>\n\n    <main class=\"w-full max-w-[440px] relative z-10\">\n      <!-- Branding & Title -->\n      <header class=\"text-center mb-10 space-y-4\">\n        <div class=\"inline-flex items-center gap-2 px-3 py-1.5 rounded-lg bg-white shadow-sm border border-slate-200\">\n          <LucideShieldCheck :size=\"14\" class=\"text-[#003366]\" />\n          <span class=\"text-xs font-bold text-slate-500\">Practitioner Portal</span>\n        </div>\n        <h1 class=\"text-4xl font-bold text-slate-800 tracking-tight\">\n          SCPSN <span class=\"text-[#003366]\">Member Login</span>\n        </h1>\n        <p class=\"text-slate-500 text-sm font-medium leading-relaxed px-4\">\n          Access your professional dashboard and scientific resources.\n        </p>\n      </header>\n      \n      <!-- Professional White Login Card -->\n      <section class=\"bg-white border border-slate-200 p-10 lg:p-12 rounded-3xl shadow-xl shadow-slate-200/40\">\n        <form @submit.prevent=\"handleLogin\" class=\"space-y-6\">\n          <!-- Email Field -->\n          <AnimatedInput \n            v-model=\"form.email\" \n            type=\"email\" \n            label=\"Email Address\"\n            placeholder=\"practitioner@institution.edu.ng\"\n          >\n            <template #right>\n              <LucideMail :size=\"18\" class=\"text-slate-400 group-focus-within:text-[#003366] transition-colors\" />\n            </template>\n          </AnimatedInput>\n\n          <!-- Password Field -->\n          <div class=\"relative\">\n            <AnimatedInput \n              v-model=\"form.password\" \n              type=\"password\" \n              label=\"Password\"\n              placeholder=\"••••••••••••\"\n            />\n            <!-- <button type=\"button\" class=\"absolute right-12 top-[18px] text-[10px] font-bold text-[#003366] uppercase tracking-widest hover:underline z-20 transition-colors\">Forgot?</button> -->\n          </div>\n\n          <!-- Login Action -->\n          <div class=\"pt-4\">\n            <button \n              type=\"submit\" \n              :disabled=\"loading\"\n              class=\"w-full flex items-center justify-center gap-4 bg-[#003366] hover:bg-[#004080] text-white py-3.5 rounded-xl text-sm font-bold shadow-md transition-all active:scale-95 disabled:opacity-50\"\n            >\n              <span v-if=\"loading\" class=\"w-4 h-4 border-2 border-white/20 border-t-white rounded-full animate-spin\"></span>\n              <span v-else class=\"flex items-center gap-2\">\n                Sign In\n                <LucideArrowRight :size=\"16\" />\n              </span>\n            </button>\n          </div>\n        </form>\n\n        <footer class=\"mt-10 pt-8 border-t border-slate-100 italic text-center\">\n          <p class=\"text-slate-400 text-[11px] font-medium leading-relaxed\">\n            \"Advancing Pathology through Scientific Excellence & Innovation\"\n          </p>\n        </footer>\n      </section>\n\n      <!-- Redirect to Signup -->\n      <nav class=\"mt-8 text-center\">\n        <p class=\"text-slate-500 text-xs font-medium\">\n          Not yet a registered member? \n          <NuxtLink to=\"/signup\" class=\"text-[#003366] font-bold hover:underline\">Apply for Membership</NuxtLink>\n        </p>\n      </nav>\n    </main>\n\n    <!-- Bottom Attribution -->\n    <footer class=\"absolute bottom-8 left-0 w-full text-center\">\n      <p class=\"text-xs font-bold text-slate-300\">&copy; 2024 Society of Clinical Pathologists</p>\n    </footer>\n  </div>\n</template>\n\n<script setup>\nimport { reactive } from 'vue'\nimport { \n  LucideMail, \n  LucideLock, \n  LucideArrowRight,\n  LucideShieldCheck\n} from 'lucide-vue-next'\nimport AnimatedInput from '@/components/AnimatedInput.vue'\nimport { useLogin } from '@/composables/modules/auth/useLogin'\nimport { useRouter } from 'vue-router'\n\nconst { loading, login } = useLogin()\nconst router = useRouter()\n\nconst form = reactive({\n  email: '',\n  password: ''\n})\n\nconst handleLogin = async () => {\n  const data = await login(form)\n  if (data) {\n    router.push('/dashboard')\n  }\n}\n</script>\n\n"],"version":3}